{
  "name": "@olist-crm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build -w @olist-crm/shared && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "worker": "tsx src/worker.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "create:user": "tsx src/scripts/createUser.ts",
    "import:history": "tsx src/scripts/importHistory.ts",
    "import:supabase:2026": "tsx src/scripts/importSupabase2026.ts",
    "test": "vitest run",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@olist-crm/shared": "0.1.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.56.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.19",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "vitest": "^3.1.3"
  }
}
